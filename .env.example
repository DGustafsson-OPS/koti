# MySQL connection (required)
DATABASE_URL=mysql://tervakuja-koti:password@127.0.0.1:3306/Koti

# Auth (required in production)
AUTH_SECRET=generate-a-long-random-string-here

# Users are managed in Settings → Users (username/password accounts stored in the database).
# Sign in with Apple (optional — leave blank to use username/password only)
# Requires Apple Developer Program ($99/year)
# 1. Create a Services ID at developer.apple.com
# 2. Enable Sign in with Apple, add domain koti.tervakuja.fi
# 3. Return URL: https://koti.tervakuja.fi/api/auth/callback/apple
# 4. Create a Sign in with Apple key (.p8) and note Key ID + Team ID
AUTH_APPLE_ID=
AUTH_APPLE_TEAM_ID=
AUTH_APPLE_KEY_ID=
AUTH_APPLE_PRIVATE_KEY=

# File uploads (optional — defaults to data/uploads beside the app)
UPLOAD_DIR=/home/tervakuja-koti/htdocs/koti.tervakuja.fi/data/uploads

# Public URL (required behind reverse proxy)
APP_URL=https://koti.tervakuja.fi

# Next.js standalone server
PORT=8088
HOSTNAME=127.0.0.1
